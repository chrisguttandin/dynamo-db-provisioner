{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/dynamo-db-provisioner/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "dependencies": {
        "aws-client-factories": "^12.0.0",
        "aws-sdk": "^2.1693.0",
        "tslib": "^2.8.1"
    },
    "description": "A lightweight and promise-based wrapper of the AWS SDK to create and delete tables.",
    "devDependencies": {
        "@babel/cli": "^7.29.7",
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@babel/register": "^7.29.7",
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-angular": "^21.2.0",
        "chai": "^4.3.10",
        "commitizen": "^4.3.2",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.39.4",
        "eslint-config-holy-grail": "^63.0.6",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "mocha": "^11.7.6",
        "prettier": "^3.9.5",
        "rimraf": "^6.1.3",
        "sinon": "^17.0.2",
        "sinon-chai": "^3.7.0",
        "tsconfig-holy-grail": "^16.0.0",
        "tslint": "^6.1.3",
        "tslint-config-holy-grail": "^57.0.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=22.22.2"
    },
    "files": [
        "build/es2019/",
        "build/node/",
        "src/"
    ],
    "homepage": "https://github.com/chrisguttandin/dynamo-db-provisioner",
    "license": "MIT",
    "main": "build/node/module.js",
    "name": "dynamo-db-provisioner",
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/dynamo-db-provisioner.git"
    },
    "scripts": {
        "build": "rimraf build/* && tsc --project src/tsconfig.json && babel ./build/es2019 --config-file ./config/babel/build.json --out-dir ./build/node",
        "lint": "npm run lint:config && npm run lint:src && npm run lint:test",
        "lint:config": "eslint --config config/eslint/config.mjs --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:src": "tslint --config config/tslint/src.json --project src/tsconfig.json src/*.ts src/**/*.ts",
        "lint:test": "eslint --config config/eslint/test.mjs --ext .js --report-unused-disable-directives test/",
        "prepare": "husky",
        "prepublishOnly": "npm run build",
        "test": "npm run lint && npm run build && npm run test:unit",
        "test:unit": "if [ \"$TYPE\" = \"\" -o \"$TYPE\" = \"unit\" ]; then mocha --bail --parallel --recursive --require config/mocha/config-unit.js test/unit; fi"
    },
    "types": "build/es2019/module.d.ts",
    "version": "10.0.1"
}
